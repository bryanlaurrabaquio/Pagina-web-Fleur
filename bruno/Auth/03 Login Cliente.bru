meta {
  name: 03 Login Cliente
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "cliente@fleur.mx",
    "password": "Cliente123!"
  }
}

script:post-response {
  if (res.body && res.body.data && res.body.data.token) {
    bru.setEnvVar("token", res.body.data.token);
  }
}
