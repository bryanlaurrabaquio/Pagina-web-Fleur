meta {
  name: 01 Register
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/register
  body: json
  auth: none
}

body:json {
  {
    "name": "Ana López",
    "email": "ana@example.com",
    "password": "Secret123"
  }
}

script:post-response {
  if (res.body && res.body.data && res.body.data.token) {
    bru.setEnvVar("token", res.body.data.token);
  }
}
